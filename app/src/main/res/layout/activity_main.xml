<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/topBarTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E3A5F"
        android:gravity="center"
        android:padding="16dp"
        android:text="A.K.Y Network Monitor"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#EEF3F8"
        android:padding="10dp"
        android:text="Ready"
        android:textColor="#111111"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/summaryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="#F7F7F7"
        android:padding="10dp"
        android:textColor="#111111"
        android:textIsSelectable="true"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal">

        <Button
            android:id="@+id/refreshButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Refresh" />

        <Button
            android:id="@+id/clearButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="Clear" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save JSON" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableLayout
                android:id="@+id/cellTowerTable"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TableRow android:background="#D9E7F5">

                    <TextView
                        android:padding="8dp"
                        android:text="No"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="TYPE"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="REG"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="MCC"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="MNC"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="AREA"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="RAW CELL ID"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="SITE ID"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="SECTOR"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="UNIQUE ID"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="PCI/PSC"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="CHANNEL"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="DBM"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="LEVEL"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="TA"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="OPERATOR"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="COUNTRY"
                        android:textStyle="bold" />

                    <TextView
                        android:padding="8dp"
                        android:text="TIMESTAMP"
                        android:textStyle="bold" />

                </TableRow>

            </TableLayout>
        </HorizontalScrollView>
    </ScrollView>

</LinearLayout>
